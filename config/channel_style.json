{
  "channel_name": "Business Video Docs",
  "tone": [
    "clear",
    "skeptical",
    "specific",
    "useful",
    "curious"
  ],
  "avoid": [
    "generic AI intros",
    "empty hype",
    "mean-spirited jokes",
    "vague stock narration"
  ],
  "target_video_length_minutes": {
    "default": 10,
    "business_tip": 8,
    "business_documentary": 10,
    "business_crime_story": 9
  },
  "music_standard": {
    "preferred_source": "C:/Users/admin/Music/royalty free music/@all/good",
    "fallback_source": "C:/Users/admin/Music/royalty free music/@all",
    "rule": "Use sorted local royalty-free music only; do not choose tracks directly from the unsorted root of @all."
  }
}
