{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bricktoon Cast",
  "type": "object",
  "required": ["style_id", "cast"],
  "properties": {
    "style_id": { "type": "string" },
    "format_id": { "type": "string" },
    "cast": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "character_id",
          "name",
          "role",
          "visual_description",
          "personality",
          "use_cases",
          "legal_notes"
        ],
        "properties": {
          "character_id": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" },
          "visual_description": { "type": "string" },
          "personality": { "type": "string" },
          "use_cases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "legal_notes": { "type": "string" }
        }
      }
    }
  }
}
